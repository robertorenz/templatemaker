# Keep Markdown files LF in the repo regardless of platform
*.md text eol=lf
# Clarion source must be CRLF — the compiler mis-parses LF-only includes
*.tpl text eol=crlf
*.tpw text eol=crlf
*.inc text eol=crlf
*.clw text eol=crlf
# bundled C compiled by Clarion's own compiler (Clacpp) — keep CRLF too
*.c text eol=crlf
*.h text eol=crlf
