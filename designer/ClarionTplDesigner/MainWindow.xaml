<Window x:Class="ClarionTplDesigner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClarionTplDesigner"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
        Title="Clarion Template Designer" Height="780" Width="1180"
        FontFamily="Segoe UI" UseLayoutRounding="True">
    <DockPanel>
      <Menu DockPanel.Dock="Top">
        <MenuItem Header="_File">
            <MenuItem Header="_Open .tpl…" Click="Open_Click"/>
            <MenuItem Header="_Save" Click="Save_Click" InputGestureText="Ctrl+S"/>
            <Separator/>
            <MenuItem Header="E_xit" Click="Exit_Click"/>
        </MenuItem>
        <MenuItem Header="_Edit">
            <MenuItem Header="_Undo" Click="Undo_Click" InputGestureText="Ctrl+Z"/>
            <Separator/>
            <MenuItem Header="Add _AT to all controls" Click="MaterializeAll_Click"/>
        </MenuItem>
        <MenuItem Header="_Insert">
            <MenuItem Header="_Label" Click="Add_Label_Click"/>
            <MenuItem Header="_String entry" Click="Add_String_Click"/>
            <MenuItem Header="_Number entry" Click="Add_Number_Click"/>
            <MenuItem Header="S_pin" Click="Add_Spin_Click"/>
            <MenuItem Header="_Check box" Click="Add_Check_Click"/>
            <MenuItem Header="_Image" Click="Add_Image_Click"/>
            <MenuItem Header="_Group box" Click="Add_Group_Click"/>
        </MenuItem>
        <MenuItem Header="_Arrange">
            <MenuItem Header="Bring to _Front" Click="Front_Click"/>
            <MenuItem Header="Bring F_orward" Click="Forward_Click"/>
            <MenuItem Header="Send _Backward" Click="Backward_Click"/>
            <MenuItem Header="Send to Bac_k" Click="Back_Click"/>
        </MenuItem>
        <MenuItem Header="St_yle">
            <MenuItem Header="_Font &amp; Colour…" Click="StyleFont_Click"/>
            <MenuItem Header="_Colour…" Click="StyleColor_Click"/>
            <MenuItem Header="_Bold" Click="StyleBold_Click"/>
            <MenuItem Header="_Larger" Click="StyleBigger_Click"/>
            <MenuItem Header="_Smaller" Click="StyleSmaller_Click"/>
        </MenuItem>
        <MenuItem Header="_Guides">
            <MenuItem Header="Add _Vertical guide" Click="AddVGuide_Click"/>
            <MenuItem Header="Add _Horizontal guide" Click="AddHGuide_Click"/>
            <MenuItem Header="_Clear guides" Click="ClearGuides_Click"/>
        </MenuItem>
        <MenuItem Header="_Preferences">
            <MenuItem x:Name="miShowGrid"  Header="Show _grid"      IsCheckable="True" Click="ShowGrid_Changed"/>
            <MenuItem x:Name="miSnapGrid"  Header="Snap to gri_d"   IsCheckable="True" IsChecked="True"/>
            <MenuItem x:Name="miSnapGuide" Header="Snap to g_uides" IsCheckable="True" IsChecked="True"/>
            <Separator/>
            <MenuItem x:Name="miMinimap"   Header="Show _minimap"   IsCheckable="True" Click="Minimap_Toggle"/>
        </MenuItem>
        <MenuItem Header="_View">
            <MenuItem x:Name="miPreview" Header="_Flow preview" IsCheckable="True" Click="Preview_Toggle"/>
            <MenuItem x:Name="miPreviewPending" Header="Preview _unsaved work (off = saved file)" IsCheckable="True" IsChecked="True" Click="PreviewPending_Toggle"/>
            <MenuItem x:Name="miViewSource" Header="_Source panel" IsCheckable="True" Click="Source_Click"/>
            <Separator/>
            <MenuItem Header="_Reset panel layout" Click="ResetLayout_Click"/>
        </MenuItem>
      </Menu>
      <ToolBarTray DockPanel.Dock="Top">
        <ToolBar Band="0" BandIndex="0">
            <TextBlock VerticalAlignment="Center" Margin="4,0">Part:</TextBlock>
            <ComboBox x:Name="cmbParts" Width="220" SelectionChanged="Part_Changed"
                      ToolTip="The template component to edit (extension / control / procedure / …), across the .tpl and its .tpw includes"/>
            <TextBlock VerticalAlignment="Center" Margin="8,0,4,0">Tab:</TextBlock>
            <ComboBox x:Name="cmbTabs" Width="140" SelectionChanged="Tab_Changed"/>
            <Separator/>
            <TextBlock VerticalAlignment="Center" Margin="4,0">Zoom</TextBlock>
            <Slider x:Name="sldZoom" Width="110" Minimum="1" Maximum="6" Value="2.5"
                    TickFrequency="0.5" IsSnapToTickEnabled="True"
                    ValueChanged="Zoom_Changed" VerticalAlignment="Center"/>
            <Separator/>
            <TextBlock VerticalAlignment="Center" Margin="4,0,2,0">Grid size</TextBlock>
            <TextBox x:Name="txtGrid" Width="32" Text="5" VerticalAlignment="Center"
                     TextChanged="GridSize_Changed"/>
            <Separator/>
            <ToggleButton x:Name="btnPreview" Click="Preview_Toggle" Padding="8,2"
                          ToolTip="Flow preview — how Clarion auto-lays out the prompts">Preview</ToggleButton>
            <ToggleButton x:Name="btnPreviewPending" Click="PreviewPending_Toggle" Padding="8,2" IsChecked="True"
                          ToolTip="ON = preview your current/unsaved work; OFF = preview the saved file on disk">Unsaved</ToggleButton>
            <ComboBox x:Name="cmbPreviewWidth" Width="124" VerticalAlignment="Center" Margin="4,0,0,0"
                      SelectionChanged="PreviewWidth_Changed"
                      ToolTip="Prompt-window width: 480 (Clarion 10 and earlier) or 960 (Clarion 11.0/11.1/12)">
                <ComboBoxItem Content="Width 480 (CW≤10)" IsSelected="True"/>
                <ComboBoxItem Content="Width 960 (CW11/12)"/>
            </ComboBox>
        </ToolBar>
        <ToolBar Band="1" BandIndex="0">
            <TextBlock VerticalAlignment="Center" Margin="4,0" Foreground="#5B6878">Text:</TextBlock>
            <TextBox x:Name="txtBarText" Width="150" VerticalAlignment="Center" TextChanged="BarText_Changed"
                     ToolTip="Caption / text / file of the selected control (added controls)"/>
            <Separator/>
            <TextBlock VerticalAlignment="Center" Margin="4,0" Foreground="#5B6878">Font:</TextBlock>
            <ComboBox x:Name="cmbFontBar" Width="130" IsEditable="True" VerticalAlignment="Center"
                      SelectionChanged="BarFont_Changed" LostFocus="BarFont_Changed"/>
            <TextBox x:Name="txtBarSize" Width="38" Margin="4,0,0,0" VerticalAlignment="Center"
                     TextChanged="BarSize_Changed" ToolTip="Font size (points)"/>
            <Button Click="StyleBold_Click"    Padding="9,2" FontWeight="Bold" ToolTip="Toggle bold">B</Button>
            <Button Click="StyleBigger_Click"  Padding="7,2" ToolTip="Larger">A▲</Button>
            <Button Click="StyleSmaller_Click" Padding="7,2" ToolTip="Smaller">A▼</Button>
            <Button Click="StyleColor_Click"   Padding="7,2" ToolTip="Colour…">Colour…</Button>
            <Button Click="StyleFont_Click"    Padding="7,2" ToolTip="Font, style &amp; colour…">Font…</Button>
        </ToolBar>
        <ToolBar Band="2" BandIndex="0">
            <TextBlock VerticalAlignment="Center" Margin="4,0" FontWeight="SemiBold" Foreground="#5B6878">Add:</TextBlock>
            <Button Click="Add_Label_Click"  Padding="6,2" ToolTip="Add a static text label (#DISPLAY)">Label</Button>
            <Button Click="Add_String_Click" Padding="6,2" ToolTip="Add a string entry (#PROMPT @s255)">String</Button>
            <Button Click="Add_Number_Click" Padding="6,2" ToolTip="Add a numeric entry (#PROMPT @n8)">Number</Button>
            <Button Click="Add_Spin_Click"   Padding="6,2" ToolTip="Add a spin control (#PROMPT SPIN)">Spin</Button>
            <Button Click="Add_Check_Click"  Padding="6,2" ToolTip="Add a checkbox (#PROMPT CHECK)">Check</Button>
            <Button Click="Add_Image_Click"  Padding="6,2" ToolTip="Add an image (#IMAGE)">Image</Button>
            <Button Click="Add_Group_Click"  Padding="6,2" ToolTip="Add a group box (#BOXED … #ENDBOXED)">Group box</Button>
        </ToolBar>
      </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock x:Name="status" Text="Open a .tpl to begin.  Drag from a ruler to add a guide; double-click a guide to delete it."/>
        </StatusBar>

        <avalonDock:DockingManager x:Name="dockMgr">
          <avalonDock:LayoutRoot>
            <avalonDock:LayoutPanel Orientation="Horizontal">
              <avalonDock:LayoutPanel Orientation="Vertical">
                <avalonDock:LayoutDocumentPane>
                  <avalonDock:LayoutDocument Title="Designer" ContentId="designer" CanClose="False" CanFloat="True">
                    <Grid x:Name="designerHost">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Row="0" Grid.Column="0" Background="#EEF1F5" BorderBrush="#D4DAE2" BorderThickness="0,0,1,1"/>
                        <local:RulerControl x:Name="hRuler" Grid.Row="0" Grid.Column="1" Orientation="Horizontal"
                                            MouseLeftButtonDown="HRuler_Down" Cursor="SizeNS"/>
                        <local:RulerControl x:Name="vRuler" Grid.Row="1" Grid.Column="0" Orientation="Vertical"
                                            MouseLeftButtonDown="VRuler_Down" Cursor="SizeWE"/>
                        <ScrollViewer x:Name="scroller" Grid.Row="1" Grid.Column="1"
                                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                      ScrollChanged="Scroller_Scroll" Background="#E7EAEF">
                            <Canvas x:Name="canvas" Background="White" Width="1000" Height="1200"
                                    MouseMove="Canvas_MouseMove" MouseLeftButtonUp="Canvas_MouseUp"
                                    MouseLeftButtonDown="Canvas_MouseDown"/>
                        </ScrollViewer>
                    </Grid>
                  </avalonDock:LayoutDocument>
                </avalonDock:LayoutDocumentPane>
                <avalonDock:LayoutAnchorablePane DockHeight="250">
                  <avalonDock:LayoutAnchorable x:Name="anchSource" Title="Source" ContentId="source" CanClose="True">
                    <DockPanel Background="#FBFCFD">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,3">
                            <Button x:Name="btnApplySrc" Click="ApplySrc_Click" Padding="9,1" IsEnabled="False"
                                    Content="Apply" ToolTip="Write these source edits to the file and re-parse"/>
                            <Button Click="RevertSrc_Click" Padding="9,1" Margin="6,0,0,0"
                                    Content="Revert" ToolTip="Discard edits and reload from disk"/>
                            <CheckBox x:Name="chkLive" Content="Live (pending)" VerticalAlignment="Center"
                                      Margin="12,0,0,0" Click="LiveSrc_Changed"
                                      ToolTip="Show the source as it would be saved, reflecting all unsaved edits (read-only)"/>
                            <TextBlock x:Name="srcHeader" VerticalAlignment="Center" Margin="10,0,0,0"
                                       FontSize="11" Foreground="#8A95A3" Text=""/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition x:Name="mapCol" Width="0"/>
                            </Grid.ColumnDefinitions>
                            <avalon:TextEditor x:Name="srcEditor" Grid.Column="0" FontFamily="Consolas" FontSize="12.5"
                                               ShowLineNumbers="True" WordWrap="False" TextChanged="SrcEditor_TextChanged"
                                               HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
                            <local:MinimapControl x:Name="srcMap" Grid.Column="1" Width="92" Cursor="Hand"
                                                  Visibility="Collapsed"/>
                        </Grid>
                    </DockPanel>
                  </avalonDock:LayoutAnchorable>
                </avalonDock:LayoutAnchorablePane>
              </avalonDock:LayoutPanel>
              <avalonDock:LayoutAnchorablePane DockWidth="250">
                <avalonDock:LayoutAnchorable x:Name="anchProps" Title="Properties" ContentId="props" CanClose="False">
                  <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#FAFBFC">
                    <StackPanel Margin="10">
                <TextBlock x:Name="propTitle" TextWrapping="Wrap" Margin="0,2,0,2" FontWeight="SemiBold"/>
                <TextBlock x:Name="propKind" Foreground="#8A95A3" FontSize="11" Margin="0,0,0,8"/>
                <Border x:Name="propTypeBox" Background="#FFF7E8" BorderBrush="#EAD9A6" BorderThickness="1"
                        CornerRadius="3" Padding="6,4" Margin="0,0,0,8" Visibility="Collapsed">
                    <TextBlock x:Name="propType" Foreground="#7A5C12" FontSize="11" TextWrapping="Wrap"/>
                </Border>
                <Border x:Name="propRefsBox" Background="#FCEEEC" BorderBrush="#E7B4AE" BorderThickness="1"
                        CornerRadius="3" Padding="6,4" Margin="0,0,0,8" Visibility="Collapsed">
                    <TextBlock x:Name="propRefs" Foreground="#B23A2E" FontSize="11" TextWrapping="Wrap"/>
                </Border>
                <TextBlock Text="Text / label / file" Foreground="#5B6878" FontSize="11" Margin="0,0,0,1"/>
                <TextBox x:Name="txtText" Margin="0,0,0,4" TextChanged="Text_Changed"
                         ToolTip="The control's text, label or image file. Editable for controls you add here."/>
                <StackPanel x:Name="imgRow" Orientation="Horizontal" Margin="0,0,0,8" Visibility="Collapsed">
                    <Button x:Name="btnBrowseImg" Click="BrowseImg_Click" Padding="10,1" Content="…"
                            ToolTip="Browse for an image file"/>
                    <Button Click="RefreshImg_Click" Padding="6,1" Margin="6,0,0,0" Content="↻ Refresh"
                            ToolTip="Reload the image and re-render (use after typing a file name or changing the file)"/>
                </StackPanel>
                <UniformGrid Columns="2" x:Name="propGrid" IsEnabled="False">
                    <TextBlock Text="X" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtX" Margin="0,2" TextChanged="Prop_Changed"/>
                    <TextBlock Text="Y" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtY" Margin="0,2" TextChanged="Prop_Changed"/>
                    <TextBlock Text="W" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtW" Margin="0,2" TextChanged="Prop_Changed"/>
                    <TextBlock Text="H" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtH" Margin="0,2" TextChanged="Prop_Changed"/>
                </UniformGrid>
                <TextBlock x:Name="styleHdr" Text="STYLE" FontWeight="Bold" Foreground="#5B6878" FontSize="11"
                           Margin="0,14,0,2" Visibility="Collapsed"/>
                <Grid x:Name="styleGrid" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Font" VerticalAlignment="Center" Margin="0,0,6,2"/>
                    <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="cmbFont" IsEditable="True" Margin="0,0,0,2"
                               SelectionChanged="Font_Changed" LostFocus="Font_Changed"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Size" VerticalAlignment="Center" Margin="0,0,6,2"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,2">
                        <TextBox x:Name="txtFontSize" Width="46" TextChanged="FontSize_Changed"/>
                        <CheckBox x:Name="chkBold" Content="Bold" VerticalAlignment="Center" Margin="10,0,0,0"
                                  Click="Bold_Changed"/>
                    </StackPanel>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Colour" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                        <Border x:Name="colorSwatch" Width="20" Height="16" BorderBrush="#AAB2BE" BorderThickness="1"
                                Background="Black" VerticalAlignment="Center"/>
                        <Button x:Name="btnColor" Content="Colour…" Padding="8,1" Margin="6,0,0,0" Click="Color_Click"/>
                        <Button x:Name="btnNoColor" Content="✕" Padding="6,1" Margin="4,0,0,0" Click="NoColor_Click"
                                ToolTip="Remove the explicit colour"/>
                    </StackPanel>
                </Grid>
                <TextBlock x:Name="srcHdr" Text="SOURCE" FontWeight="Bold" Foreground="#5B6878" FontSize="11"
                           Margin="0,14,0,2" Visibility="Collapsed"/>
                <TextBox x:Name="propSource" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas"
                         FontSize="11" Background="#F4F6F9" BorderBrush="#DDE2E8" Padding="4"
                         MaxHeight="130" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"/>
                <TextBlock x:Name="childHdr" Text="CONTROLS IN GROUP" FontWeight="Bold" Foreground="#5B6878"
                           FontSize="11" Margin="0,14,0,2" Visibility="Collapsed"/>
                <ListBox x:Name="lstChildren" Height="150" FontSize="11" Visibility="Collapsed"
                         FontFamily="Consolas" SelectionChanged="Children_Select"/>
                <TextBlock Text="Tip: arrow keys nudge the selection 1 unit (Shift = 5). Drop a control inside a group box to add it to that group; drag it out to remove it."
                           Foreground="#8A95A3" FontSize="11" TextWrapping="Wrap" Margin="0,12,0,0"/>
                    </StackPanel>
                  </ScrollViewer>
                </avalonDock:LayoutAnchorable>
              </avalonDock:LayoutAnchorablePane>
            </avalonDock:LayoutPanel>
          </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>
    </DockPanel>
</Window>
