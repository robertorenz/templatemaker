<Window x:Class="ClarionTplDesigner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClarionTplDesigner"
        Title="Clarion Template Designer" Height="780" Width="1180"
        FontFamily="Segoe UI" UseLayoutRounding="True">
    <DockPanel>
        <ToolBar DockPanel.Dock="Top">
            <Button Click="Open_Click" Padding="8,2">Open .tpl…</Button>
            <Button Click="Save_Click" Padding="8,2">Save</Button>
            <Separator/>
            <TextBlock VerticalAlignment="Center" Margin="4,0">Tab:</TextBlock>
            <ComboBox x:Name="cmbTabs" Width="140" SelectionChanged="Tab_Changed"/>
            <Separator/>
            <TextBlock VerticalAlignment="Center" Margin="4,0">Zoom</TextBlock>
            <Slider x:Name="sldZoom" Width="110" Minimum="1" Maximum="6" Value="2.5"
                    TickFrequency="0.5" IsSnapToTickEnabled="True"
                    ValueChanged="Zoom_Changed" VerticalAlignment="Center"/>
            <Separator/>
            <CheckBox x:Name="chkSnapGrid" IsChecked="True" VerticalAlignment="Center" Margin="2,0">Snap grid</CheckBox>
            <TextBlock VerticalAlignment="Center" Margin="6,0,2,0">size</TextBlock>
            <TextBox x:Name="txtGrid" Width="32" Text="5" VerticalAlignment="Center"/>
            <CheckBox x:Name="chkSnapGuide" IsChecked="True" VerticalAlignment="Center" Margin="8,0">Snap guides</CheckBox>
            <Separator/>
            <Button Click="AddVGuide_Click" Padding="6,2">+ V guide</Button>
            <Button Click="AddHGuide_Click" Padding="6,2">+ H guide</Button>
            <Button Click="ClearGuides_Click" Padding="6,2">Clear guides</Button>
        </ToolBar>

        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock x:Name="status" Text="Open a .tpl to begin.  Drag from a ruler to add a guide; double-click a guide to delete it."/>
        </StatusBar>

        <Border DockPanel.Dock="Right" Width="230" BorderBrush="#DDE2E8" BorderThickness="1,0,0,0" Background="#FAFBFC">
            <StackPanel Margin="10">
                <TextBlock Text="PROPERTIES" FontWeight="Bold" Foreground="#5B6878" FontSize="11"/>
                <TextBlock x:Name="propTitle" TextWrapping="Wrap" Margin="0,6,0,2" FontWeight="SemiBold"/>
                <TextBlock x:Name="propKind" Foreground="#8A95A3" FontSize="11" Margin="0,0,0,8"/>
                <UniformGrid Columns="2" x:Name="propGrid" IsEnabled="False">
                    <TextBlock Text="X" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtX" Margin="0,2" TextChanged="Prop_Changed"/>
                    <TextBlock Text="Y" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtY" Margin="0,2" TextChanged="Prop_Changed"/>
                    <TextBlock Text="W" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtW" Margin="0,2" TextChanged="Prop_Changed"/>
                    <TextBlock Text="H" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtH" Margin="0,2" TextChanged="Prop_Changed"/>
                </UniformGrid>
                <TextBlock Text="Tip: arrow keys nudge the selection 1 unit (Shift = 5)."
                           Foreground="#8A95A3" FontSize="11" TextWrapping="Wrap" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="22"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="22"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Background="#EEF1F5" BorderBrush="#D4DAE2" BorderThickness="0,0,1,1"/>
            <local:RulerControl x:Name="hRuler" Grid.Row="0" Grid.Column="1" Orientation="Horizontal"
                                MouseLeftButtonDown="HRuler_Down" Cursor="SizeNS"/>
            <local:RulerControl x:Name="vRuler" Grid.Row="1" Grid.Column="0" Orientation="Vertical"
                                MouseLeftButtonDown="VRuler_Down" Cursor="SizeWE"/>

            <ScrollViewer x:Name="scroller" Grid.Row="1" Grid.Column="1"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          ScrollChanged="Scroller_Scroll" Background="#E7EAEF">
                <Canvas x:Name="canvas" Background="White" Width="1000" Height="1200"
                        MouseMove="Canvas_MouseMove" MouseLeftButtonUp="Canvas_MouseUp"
                        MouseLeftButtonDown="Canvas_MouseDown"/>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
